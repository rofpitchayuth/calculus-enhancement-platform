# Hugging Face Token (Optional, for downloading gated models if needed)
HF_TOKEN=your_huggingface_token_here

# Google Gemini API Key (Required for Flash Vision OCR and hybrid formatting pipeline)
GEMINI_API_KEY=your_gemini_api_key_here

# Remote or Local Ollama API URL (e.g. Tailscale IP or localhost)
LLM_API_BASE_URL=http://localhost:11434

# LLM model name used for solving calculus questions (Ollama or remote)
LLM_MODEL_NAME=qwen2.5-math-7b-instruct
